[Unit]
Description=Farah Nuxt website
After=network.target

[Service]
Type=simple
User=hal
WorkingDirectory=/home/hal/coding/farah-nuxt
EnvironmentFile=/home/hal/coding/farah-nuxt/.env
Environment=NODE_ENV=production
Environment=HOST=127.0.0.1
Environment=PORT=3000
ExecStart=/usr/bin/node /home/hal/coding/farah-nuxt/.output/server/index.mjs
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
